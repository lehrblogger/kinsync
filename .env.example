FS_COOKIES=your_full_cookie_string_here
CRON_SECRET=your_secret_here

# Gitea (optional, for audit trail)
GITEA_URL=https://gitea.example.com
GITEA_TOKEN=your_personal_access_token
GITEA_OWNER=your_username
GITEA_REPO=radicale-steven
# GITEA_BRANCH=main  # optional, defaults to main

# Git archive (optional, pushes Radicale data to a remote repo after each sync)
GIT_REMOTE_URL=https://<username>:<token>@github.com/<username>/kinsync-data.git

# Radicale (Docker/Fly.io deployment)
RADICALE_USER=steven
RADICALE_CALENDAR=four-seasons
RADICALE_PASSWORD=your_radicale_password  # only needed on first container start
