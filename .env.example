FS_COOKIES=your_full_cookie_string_here
CRON_SECRET=your_secret_here

# Git archive (optional, pushes Radicale data to a remote repo after each sync)
GIT_REMOTE_URL=https://<username>:<token>@github.com/<username>/kinsync-data.git

# Radicale (Docker/Fly.io deployment)
RADICALE_SYNC_USER=your_family_name  # namespace for shared/managed calendars; becomes the CalDAV path prefix
RADICALE_SYNC_PASSWORD=your_service_account_password
RADICALE_CALENDAR=four-seasons
# Family member accounts (optional, only needed on first container start to create htpasswd entries)
RADICALE_USER=your_username
RADICALE_PASSWORD=your_radicale_password
