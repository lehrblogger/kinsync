# Required — used to authenticate all sync and debug endpoints
CRON_SECRET=your_secret_here

# Four Seasons (optional — FS sync is skipped if FS_COOKIES is not set)
FS_COOKIES=your_full_cookie_string_here
FS_CALENDAR=four-seasons

# Wanderlog (optional — Wanderlog sync is skipped if WANDERLOG_COOKIE is not set)
WANDERLOG_COOKIE=your_wanderlog_cookie_here
WANDERLOG_CALENDAR=wanderlog

# Git archive (optional — pushes the JSON store to a remote repo after each sync)
GIT_REMOTE_URL=https://<username>:<token>@github.com/<username>/kinsync-archive.git

# Radicale — service account used by the sync process to write calendars
RADICALE_SYNC_USER=your_family_name
RADICALE_SYNC_PASSWORD=your_service_account_password

# Radicale — individual user accounts (optional, only needed on first container start)
RADICALE_USER=your_username
RADICALE_PASSWORD=your_radicale_password
